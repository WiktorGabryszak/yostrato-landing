---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const apiUrl = import.meta.env.WORDPRESS_API_URL || process.env.WORDPRESS_API_URL;
  const url = `${apiUrl}/posts?_embed&per_page=100`;
  try {
    const response = await fetch(url);
    if (!response.ok) {
      console.error(`WordPress API returned status ${response.status} for URL: ${url}`);
      return [];
    }
    const contentType = response.headers.get("content-type");
    if (!contentType || !contentType.includes("application/json")) {
      const bodyText = await response.text();
      console.error(`WordPress API returned non-JSON response for URL: ${url}. Response body: ${bodyText.substring(0, 300)}`);
      return [];
    }
    const posts = await response.json();
    if (!Array.isArray(posts)) {
      console.error(`WordPress API did not return an array for URL: ${url}. Received:`, posts);
      return [];
    }
    return posts.map((post: any) => ({
      params: { slug: post.slug },
      props: { post },
    }));
  } catch (e) {
    console.error(`Failed to fetch posts from WordPress API for URL: ${url}`, e);
    return [];
  }
}

const { post: staticPost } = Astro.props;
let post = staticPost;

if (import.meta.env.DEV) {
  const apiUrl = import.meta.env.WORDPRESS_API_URL || process.env.WORDPRESS_API_URL;
  const { slug } = Astro.params;
  try {
    const response = await fetch(`${apiUrl}/posts?slug=${slug}&_embed`);
    if (response.ok) {
      const contentType = response.headers.get("content-type");
      if (contentType && contentType.includes("application/json")) {
        const posts = await response.json();
        if (Array.isArray(posts) && posts.length > 0) {
          post = posts[0];
        }
      }
    }
  } catch (e) {
    console.error("Failed to fetch fresh post data in dev mode:", e);
  }
}

const seoData = {
  description: post.yoast_head_json?.description || post.rank_math_description,
  og_title: post.yoast_head_json?.og_title || post.rank_math_title,
  og_description: post.yoast_head_json?.og_description || post.rank_math_description,
  og_image: post.yoast_head_json?.og_image?.[0]?.url || post._embedded?.['wp:featuredmedia']?.[0]?.source_url,
  canonical: post.yoast_head_json?.canonical || post.rank_math_canonical
};
---

<Layout seoData={seoData} title={post.title.rendered}>
  <article class="single-post">
    <header class="post-header">
      <span class="post-date">{new Date(post.date).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
      <h1 class="post-title" set:html={post.title.rendered} />
    </header>
    
    <div class="post-content wp-content" set:html={post.content.rendered} />
  </article>
</Layout>

<style>
  .single-post {
    background: var(--c-white);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 24px;
    padding: 64px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
  }

  .post-header {
    border-bottom: 1px solid #f1f1f5;
    padding-bottom: 32px;
    margin-bottom: 40px;
    text-align: center;
  }

  .post-date {
    font-size: 14px;
    font-weight: 600;
    color: var(--c-orange);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: block;
    margin-bottom: 16px;
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.25;
    color: var(--c-dark);
    margin: 0;
    letter-spacing: -0.8px;
  }

  .post-content {
    font-size: 1.05rem;
    line-height: 1.85;
    color: #444;
  }

  @media (max-width: 768px) {
    .single-post {
      padding: 40px 20px;
    }
    .post-title {
      font-size: 1.85rem;
    }
  }
</style>

<style is:global>
  .wp-content p {
    margin-bottom: 24px;
  }

  .wp-content h2 {
    font-size: 1.65rem;
    font-weight: 700;
    margin-top: 48px;
    margin-bottom: 20px;
    color: var(--c-dark);
  }

  .wp-content h3 {
    font-size: 1.35rem;
    font-weight: 700;
    margin-top: 36px;
    margin-bottom: 16px;
    color: var(--c-dark);
  }

  .wp-content img {
    max-width: 100%;
    height: auto;
    border-radius: 16px;
    margin: 32px 0;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
  }

  .wp-content ul, .wp-content ol {
    margin-bottom: 24px;
    padding-left: 24px;
  }

  .wp-content li {
    margin-bottom: 8px;
  }

  .wp-content blockquote {
    border-left: 4px solid var(--c-orange);
    padding-left: 20px;
    margin: 32px 0;
    font-style: italic;
    color: #666;
  }
</style>
