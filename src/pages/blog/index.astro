---
import Layout from '../../layouts/Layout.astro';

const apiUrl = import.meta.env.WORDPRESS_API_URL || process.env.WORDPRESS_API_URL;
const cb = Date.now();
const url = `${apiUrl}/posts?_embed&per_page=100&cb=${cb}`;
let posts = [];
try {
  const response = await fetch(url, {
    headers: {
      'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
      'Accept': 'application/json, text/plain, */*'
    }
  });
  if (response.ok) {
    const contentType = response.headers.get("content-type");
    if (contentType && contentType.includes("application/json")) {
      posts = await response.json();
    } else {
      const bodyText = await response.text();
      console.error(`WordPress API returned non-JSON response for URL: ${url}. Response body: ${bodyText.substring(0, 300)}`);
    }
  } else {
    console.error(`WordPress API returned status ${response.status} for URL: ${url}`);
  }
} catch (e) {
  console.error(`Failed to fetch posts from WordPress API for URL: ${url}`, e);
}
---

<Layout title="Blog - Articles & Insights">
  <div class="blog-header">
    <h1 class="blog-main-title">Articles & Insights</h1>
    <p class="blog-subtitle">Our latest thoughts, guides, and business tips managed from WordPress.</p>
  </div>
  
  <div class="blog-grid">
    {Array.isArray(posts) && posts.map((post: any) => (
      <article class="post-card">
        <div class="card-content">
          <span class="card-date">{new Date(post.date).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          <h2 class="card-title" set:html={post.title.rendered} />
          <div class="card-excerpt" set:html={post.excerpt.rendered} />
        </div>
        <a href={`/blog/${post.slug}`} class="card-link">
          Read Article <span class="card-arrow">&rarr;</span>
        </a>
      </article>
    ))}
  </div>
</Layout>

<style>
  .blog-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .blog-main-title {
    font-size: 2.75rem;
    font-weight: 800;
    color: var(--c-dark);
    margin-bottom: 12px;
    letter-spacing: -0.8px;
  }

  .blog-subtitle {
    font-size: 1.15rem;
    color: #666;
    margin: 0;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 32px;
  }

  .post-card {
    background: var(--c-white);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 20px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease, border-color 0.3s ease;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.06);
    border-color: rgba(255, 95, 62, 0.15);
  }

  .card-date {
    font-size: 13px;
    font-weight: 600;
    color: var(--c-orange);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: block;
    margin-bottom: 12px;
  }

  .card-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--c-dark);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .card-excerpt {
    font-size: 14.5px;
    line-height: 1.6;
    color: #555;
    margin-bottom: 24px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-link {
    font-size: 14px;
    font-weight: 700;
    color: var(--c-orange);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease;
  }

  .post-card:hover .card-link {
    color: var(--c-orange-deep);
  }

  .card-arrow {
    transition: transform 0.2s ease;
  }

  .card-link:hover .card-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
