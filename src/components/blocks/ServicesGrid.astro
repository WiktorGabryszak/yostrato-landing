---
/**
 * ACF layout: `services_grid`
 * Numbered service cards (image, 01/02/03 badge, title, blurb, link).
 * `services` can come from a repeater now or the `service` CPT later —
 * the component only cares about the row shape.
 */
import type { ServicesGridBlock } from '../../lib/types';
import { acfImage } from '../../lib/wp';

type Props = Omit<ServicesGridBlock, 'acf_fc_layout'>;

const {
  section_eyebrow = 'Our drainage services',
  section_heading,
  section_intro,
  services = [],
} = Astro.props;

const cards = (services ?? []).filter((s) => s?.service_title);
---

{
  cards.length > 0 && (
    <section id="services" class="bg-surface py-16 lg:py-[110px]">
      <div class="wrap">
        <div class="flex items-end justify-between gap-10 mb-[52px] flex-wrap">
          <div class="max-w-[560px]">
            {section_eyebrow && (
              <p class="m-0 mb-5">
                <span class="eyebrow bg-white">{section_eyebrow}</span>
              </p>
            )}
            {section_heading && <h2 class="m-0 heading-xl text-navy">{section_heading}</h2>}
          </div>
          {section_intro && (
            <p class="m-0 mb-1.5 text-muted text-base leading-[1.65] max-w-[380px] text-pretty">{section_intro}</p>
          )}
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-7">
          {cards.map((card) => {
            const photo = acfImage(card.service_image, card.service_title ?? '');
            return (
              <article class="group bg-white border border-line rounded-[18px] overflow-hidden flex flex-col shadow-card transition-[transform,box-shadow] duration-[250ms] ease-out hover:-translate-y-1.5 hover:shadow-card-hover">
                {photo && (
                  <div class="relative aspect-[4/3]">
                    <img src={photo.url} alt={photo.alt} class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
                    {card.service_number && (
                      <span class="absolute top-4 right-4 bg-white text-navy font-display text-[19px] px-3.5 py-2 rounded-[10px] shadow-number pointer-events-none">
                        {card.service_number}
                      </span>
                    )}
                  </div>
                )}
                <div class="px-7 pt-7 pb-[30px] flex flex-col gap-3 flex-1">
                  <h3 class="m-0 font-display font-normal text-[25px] tracking-[0.015em] uppercase text-navy">
                    {card.service_title}
                  </h3>
                  {card.service_short_description && (
                    <p class="m-0 text-muted text-[15px] leading-[1.65] flex-1">{card.service_short_description}</p>
                  )}
                  {card.service_link_label && (
                    <a
                      href={card.service_link || '/#contact'}
                      class="inline-flex items-center gap-2 text-blue font-bold text-[15px] mt-1.5 hover:text-sky"
                    >
                      {card.service_link_label}
                      <span aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-1">
                        →
                      </span>
                    </a>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )
}
