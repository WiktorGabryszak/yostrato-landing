---
/**
 * ACF layout: `gallery`
 * Full-bleed photo grid with white category/caption label cards.
 * `items` can come from a repeater now or the `gallery_item` CPT later.
 */
import type { GalleryBlock } from '../../lib/types';
import { acfImage } from '../../lib/wp';

type Props = Omit<GalleryBlock, 'acf_fc_layout'>;

const {
  section_eyebrow = 'Work gallery',
  section_heading,
  section_intro,
  items = [],
} = Astro.props;

const photos = (items ?? [])
  .map((item) => ({ ...item, photo: acfImage(item.image, item.caption ?? '') }))
  .filter((item) => item.photo);
---

{
  photos.length > 0 && (
    <section id="gallery" class="bg-white py-16 lg:py-[110px]">
      <div class="wrap">
        <div class="flex items-end justify-between gap-10 mb-[52px] flex-wrap">
          <div class="max-w-[560px]">
            {section_eyebrow && (
              <p class="m-0 mb-5">
                <span class="eyebrow bg-white">{section_eyebrow}</span>
              </p>
            )}
            {section_heading && <h2 class="m-0 heading-xl text-navy">{section_heading}</h2>}
          </div>
          {section_intro && (
            <p class="m-0 mb-1.5 text-muted text-[15px] leading-[1.6] max-w-[360px]">{section_intro}</p>
          )}
        </div>
      </div>
      <div class="w-full box-border px-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
          {photos.map((item) => (
            <div class="relative aspect-[3/2.6] rounded-[20px] overflow-hidden">
              <img
                src={item.photo!.url}
                alt={item.photo!.alt || item.caption || ''}
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
              {(item.category || item.caption) && (
                <div class="absolute left-5 right-5 bottom-5 bg-white rounded-[14px] px-5 py-4 shadow-label">
                  {item.category && (
                    <span class="block text-faint text-[11px] font-extrabold tracking-[0.12em] uppercase mb-1.5">
                      {item.category}
                    </span>
                  )}
                  {item.caption && <span class="block text-navy text-[17px] font-extrabold">{item.caption}</span>}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
