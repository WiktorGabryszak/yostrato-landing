---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  paragraphs: string[];
  ctaLabel: string;
  ctaHref: string;
  image: string;
  imageAlt: string;
  imageSide?: "left" | "right";
  variant?: "a" | "b";
  priority?: boolean;
}

const {
  title,
  paragraphs,
  ctaLabel,
  ctaHref,
  image,
  imageAlt,
  imageSide = "right",
  variant = "a",
  priority = false,
} = Astro.props;
---

<div class={`service-block variant-${variant} image-${imageSide}`}>
  <div class="text-panel">
    <div class="text-inner">
      <h2>{title}</h2>
      {paragraphs.map((p) => <p set:html={p} />)}
      <a href={ctaHref} class="btn btn-primary">
        <span>{ctaLabel}</span>
        <span class="btn-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4l6 6-6 6"/><path d="M12 4l6 6-6 6"/></svg>
        </span>
      </a>
    </div>
  </div>
  <div class="image-panel">
    <Image
      src={image}
      widths={[480, 768, 900, 1024]}
      sizes="(max-width: 900px) 100vw, 50vw"
      width={900}
      height={600}
      alt={imageAlt}
      loading={priority ? "eager" : "lazy"}
      fetchpriority={priority ? "high" : "auto"}
    />
  </div>
</div>

<style>
  .service-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 480px;
  }

  .variant-a .text-panel {
    background: var(--gradient-block-a);
  }

  .variant-b .text-panel {
    background: var(--gradient-block-b);
  }

  .image-left {
    direction: rtl;
  }

  .image-left .text-panel,
  .image-left .image-panel {
    direction: ltr;
  }

  .text-panel {
    display: flex;
    align-items: center;
    padding: 60px;
  }

  .text-inner {
    max-width: 460px;
  }

  .text-panel h2 {
    color: var(--c-white);
    font-size: clamp(22px, 2.4vw, 30px);
  }

  .text-panel p {
    color: var(--c-muted);
    font-size: 15px;
  }

  .image-panel {
    overflow: hidden;
  }

  .image-panel img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 320px;
  }

  @media (max-width: 900px) {
    .service-block,
    .image-left {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .image-panel {
      order: -1;
    }

    .text-panel {
      padding: 44px 28px;
    }

    .image-panel img {
      min-height: 260px;
    }
  }
</style>
