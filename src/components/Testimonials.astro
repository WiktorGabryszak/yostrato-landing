---

<section class="testimonials" id="testimonials">
  <div class="container">
    <h2>Testimonials</h2>

    <div class="slides">
      {testimonials.map((t, i) => (
        <div class={`slide ${i === 0 ? "active" : ""}`} data-index={i}>
          <div class="quote-wrap">
            <span class="mark mark-open" aria-hidden="true">&ldquo;</span>
            <p class="attribution">{t.role ? `${t.name} · ${t.role}` : t.name}</p>
            {t.quote.map((paragraph) => <p class="quote">{paragraph}</p>)}
            <span class="mark mark-close" aria-hidden="true">&rdquo;</span>
          </div>
        </div>
      ))}
    </div>

    <div class="dots" role="tablist" aria-label="Testimonial selector">
      {testimonials.map((_, i) => (
        <button
          class={`dot ${i === 0 ? "active" : ""}`}
          data-index={i}
          aria-label={`Show testimonial ${i + 1}`}
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
        ></button>
      ))}
    </div>
  </div>

  <svg class="wave" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
    <path
      fill="#ffffff"
      d="M0,64 C240,120 480,0 720,32 C960,64 1200,120 1440,64 L1440,120 L0,120 Z"
    ></path>
  </svg>
</section>

<style>
  .testimonials {
    position: relative;
    background: var(--gradient-hero);
    padding: 100px 0 150px;
    overflow: hidden;
    text-align: center;
  }

  .testimonials .container {
    position: relative;
    z-index: 2;
  }

  .testimonials h2 {
    color: var(--c-white);
    font-size: clamp(24px, 3vw, 34px);
    margin-bottom: 56px;
  }

  .slides {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
  }

  .slide {
    display: none;
  }

  .slide.active {
    display: block;
  }

  .quote-wrap {
    position: relative;
    padding: 0 40px;
  }

  .mark {
    position: absolute;
    font-family: Georgia, serif;
    font-size: 64px;
    line-height: 1;
    color: rgba(255, 255, 255, 0.35);
  }

  .mark-open {
    top: -18px;
    left: -6px;
  }

  .mark-close {
    bottom: -34px;
    right: -6px;
  }

  .attribution {
    color: var(--c-white);
    font-family: var(--font-heading);
    font-weight: 700;
    font-style: italic;
    font-size: 15px;
    margin-bottom: 20px;
  }

  .quote {
    color: var(--c-muted);
    font-style: italic;
    font-size: 16px;
    line-height: 1.8;
  }

  .dots {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    max-width: 480px;
    margin: 48px auto 0;
  }

  .dot {
    position: relative;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .dot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 48px;
    height: 48px;
    transform: translate(-50%, -50%);
  }

  .dot.active {
    background: var(--c-white);
  }

  .wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 90px;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .testimonials {
      padding: 80px 0 120px;
    }

    .mark {
      font-size: 46px;
    }

    .quote-wrap {
      padding: 0 24px;
    }
  }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>(".testimonials .slide");
  const dots = document.querySelectorAll<HTMLButtonElement>(".testimonials .dot");
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function show(index: number) {
    slides.forEach((s, i) => s.classList.toggle("active", i === index));
    dots.forEach((d, i) => {
      d.classList.toggle("active", i === index);
      d.setAttribute("aria-selected", i === index ? "true" : "false");
    });
    current = index;
  }

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(() => show((current + 1) % slides.length), 9000);
  }

  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      show(Number(dot.dataset.index));
      resetTimer();
    });
  });

  resetTimer();
</script>
