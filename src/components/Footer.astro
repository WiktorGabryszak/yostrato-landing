---
const year = new Date().getFullYear();

const services = [
  { label: "Website Design", href: "https://yostrato.com/website-design/" },
  { label: "e-Commerce", href: "https://yostrato.com/e-commerce/" },
  { label: "Search Engine Optimisation", href: "https://yostrato.com/seo/" },
  { label: "Marketing Automation", href: "https://yostrato.com/marketing-automation/" },
  { label: "Business Insights", href: "https://yostrato.com/business-insights/" },
  { label: "Web Applications", href: "https://yostrato.com/webapps/" },
];

const blogPosts = [
  { title: "When Off-the-Shelf Software Stops Working", href: "https://yostrato.com/automation/custom-web-app/" },
  { title: "Signs Your Business Needs a Bespoke Web Application", href: "https://yostrato.com/automation/business-bespoke-web-application/" },
  { title: "Why Working With an Agency for SEO Helps Businesses Grow Online", href: "https://yostrato.com/automation/agency-for-seo/" },
];
---

<footer class="site-footer">
  <div class="follow-bar">
    <div class="container">
      <div class="follow-inner">
        <div class="follow-col">
          <span class="follow-label">Follow Us</span>
        </div>
        <div class="follow-col">
          <a href="https://www.facebook.com/YostratO/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.5 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.9h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94z"/></svg>
          </a>
        </div>
        <div class="follow-col">
          <a href="https://www.linkedin.com/company/yostrato/about/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.15 1.45-2.15 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="container footer-grid">
    <div class="footer-col">
      <h3>About YostratO</h3>
      <p>The web design company with honesty and transparency at its core.</p>
      <a href="https://yostrato.com/privacy/">Privacy Policy</a>
    </div>

    <div class="footer-col">
      <h3>Our Services</h3>
      <ul>
        {services.map((s) => (
          <li><a href={s.href}>{s.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h3>Recent Blog Posts</h3>
      <ul>
        {blogPosts.map((post) => (
          <li><a href={post.href}>{post.title}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h3>Contact</h3>
      <p>
        tel: <a href="tel:+441296793010">01296 793010</a><br />
        e: <a href="mailto:office@yostrato.com">office@yostrato.com</a>
      </p>
      <address>
        YostratO<br />
        Office 4, Market House<br />
        Market Square<br />
        Aylesbury HP20 1TN
      </address>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <a href="#home" class="footer-logo" aria-label="YostratO home">
        <img src="/yostrato-website-logo.png" alt="YostratO" class="footer-logo-image" width="350" height="38" />
      </a>
      <p>&copy; {year} All rights reserved. YostratO Ltd.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--gradient-hero);
    color: var(--c-white);
    padding-top: 0;
  }

  .follow-bar {
    width: min(100%, var(--container-w));
    background: var(--c-white);
    margin: 0 auto;
    transform: translateY(-28px);
    border-radius: 28px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12);
    overflow: hidden;
  }

  .follow-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .follow-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 36px 24px;
  }

  .follow-col:first-child {
    justify-content: flex-start;
    padding-left: 40px;
  }

  .follow-col + .follow-col {
    border-left: 1px solid rgba(0, 0, 0, 0.08);
  }

  .follow-label {
    color: var(--c-dark);
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.5px;
    font-size: 15px;
    text-transform: uppercase;
  }

  .follow-col a {
    color: var(--c-dark);
    display: inline-flex;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .follow-col a:hover {
    color: var(--c-orange-deep);
    transform: translateY(-2px);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    padding: 12px 24px 50px;
  }

  .footer-col h3 {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--c-white);
    margin-bottom: 18px;
  }

  .footer-col p,
  .footer-col address {
    color: var(--c-muted);
    font-size: 14px;
    font-style: normal;
    line-height: 1.7;
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col a {
    color: var(--c-muted);
    font-size: 14px;
  }

  .footer-col a:hover {
    color: var(--c-white);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding: 32px 24px 40px;
    text-align: center;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    margin-bottom: 12px;
  }

  .footer-logo-image {
    display: block;
    width: 160px;
    height: auto;
  }

  .footer-bottom p {
    color: var(--c-muted);
    font-size: 13px;
    margin: 0;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .follow-inner {
      grid-template-columns: 1fr;
    }

    .follow-col:first-child {
      justify-content: center;
      padding-left: 24px;
    }

    .follow-col + .follow-col {
      border-left: none;
      border-top: 1px solid rgba(0, 0, 0, 0.08);
    }
  }
</style>
